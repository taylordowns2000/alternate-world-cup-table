# Copy this file to ".env" and fill in the values. NEVER commit .env.

# football-data.org API token — free, instant: https://www.football-data.org/client/register
FOOTBALL_DATA_TOKEN=your_football_data_token

# Supabase project URL (same as in wc2026-table.html)
SUPABASE_URL=https://kacbkjjdnumtpbwliqry.supabase.co

# Supabase SECRET key (sb_secret_... / service_role). Dashboard → Project Settings
# → API keys → "secret". This bypasses row-level security so it can WRITE scores.
# Keep it server-side only. Do NOT put it in the HTML page.
SUPABASE_SERVICE_KEY=your_supabase_secret_key
